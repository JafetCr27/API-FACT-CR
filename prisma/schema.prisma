generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id              String    @id @default(uuid())
  name            String
  identification  String    @unique
  apiKey          String @unique
  haciendaUser    String
  haciendaPassword String
  certPath        String
  certPassword    String
  environment     String

  documents       Document[]  // ✅ relación
}
model Document {
  id          String   @id @default(uuid())
  companyId   String
  type        String
  clave       String
  status      String
  xml         String
  xmlFirmado  String
  response    String
  createdAt   DateTime @default(now())

  // 🔥 RELACIÓN INVERSA (OBLIGATORIA)
  company     Company @relation(fields: [companyId], references: [id])
}