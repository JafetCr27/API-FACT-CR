generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id               String   @id @default(uuid())
  name             String
  commercialName   String   
  identification   String   @unique
  apiKey           String   @unique

  haciendaUser     String
  haciendaPassword String

  certPath         String
  certPassword     String

  environment      String

  activityCode     String
  phoneCountryCode String?
  phone            String?
  email            String

  province         String
  canton           String
  district         String
  otherSigns       String

  identificationType String

  createdAt        DateTime @default(now())

  documents        Document[]
  users            UserCompany[]
}
model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  status       String   @default("active")
  createdAt    DateTime @default(now())

  companies    UserCompany[]
}
model UserCompany {
  id         String  @id @default(uuid())
  userId     String
  companyId  String
  role       String  // admin, contador, facturador

  user       User    @relation(fields: [userId], references: [id])
  company    Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
}

model Document {

  id                             String   @id @default(uuid())

  companyId                      String

  type                           String

  clave                          String?  @unique

  consecutivo                    String?  @unique

  receptorNombre                 String

  receptorIdentificacion         String

  receptorEmail                  String?

  receptorIdentificationType     String

  saleCondition                  String

  paymentMethod                  String

  currency                       String   @default("CRC")

  exchangeRate                   Float?  @default(1)

  subtotal                       Float    @default(0)

  tax                            Float    @default(0)

  total                          Float    @default(0)

  status                         String   @default("draft")

  xml                            String?

  xmlSigned                      String?

  haciendaResponse               String?

  createdAt                      DateTime @default(now())

  updatedAt                      DateTime @updatedAt

  company                        Company @relation(fields: [companyId], references: [id])

  lines                          DocumentLine[]

  @@index([companyId])

  @@index([status])

  @@index([createdAt])
}

model DocumentLine {

  id               String   @id @default(uuid())

  documentId       String

  lineNumber       Int

  codeType         String?

  codigo           String?

  descripcion      String

  cantidad         Float

  unidadMedida     String   @default("Unid")

  precioUnitario   Float

  subtotal         Float

  taxCode          String?

  taxRateCode      String?

  taxRate          Float?

  impuesto         Float    @default(0)

  totalLinea       Float

  createdAt        DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}